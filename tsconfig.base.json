{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ui/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@ui/shared-ui/accordion": ["libs/shared-ui/accordion/index.ts"],
      "@ui/shared-ui/alert": ["libs/shared-ui/alert/index.ts"],
      "@ui/shared-ui/avatar": ["libs/shared-ui/avatar/index.ts"],
      "@ui/shared-ui/badge": ["libs/shared-ui/badge/index.ts"],
      "@ui/shared-ui/breadcrumb": ["libs/shared-ui/breadcrumb/index.ts"],
      "@ui/shared-ui/button": ["libs/shared-ui/button/index.ts"],
      "@ui/shared-ui/checkbox": ["libs/shared-ui/checkbox/index.ts"],
      "@ui/shared-ui/icon": ["libs/shared-ui/icon/index.ts"],
      "@ui/shared-ui/input": ["libs/shared-ui/input/index.ts"],
      "@ui/shared-ui/list-item": ["libs/shared-ui/list-item/index.ts"],
      "@ui/shared-ui/multi-select": ["libs/shared-ui/multi-select/index.ts"],
      "@ui/shared-ui/icon-button": ["libs/shared-ui/icon-button/index.ts"],
      "@ui/shared-ui/progress-bar": ["libs/shared-ui/progress-bar/index.ts"],
      "@ui/shared-ui/radio": ["libs/shared-ui/radio/index.ts"],
      "@ui/shared-ui/select": ["libs/shared-ui/select/index.ts"],
      "@ui/shared-ui/slider": ["libs/shared-ui/slider/index.ts"],
      "@ui/shared-ui/spinner": ["libs/shared-ui/spinner/index.ts"],
      "@ui/shared-ui/tabs": ["libs/shared-ui/tabs/index.ts"],
      "@ui/shared-ui/tag": ["libs/shared-ui/tag/index.ts"],
      "@ui/shared-ui/textarea": ["libs/shared-ui/textarea/index.ts"],
      "@ui/shared-ui/toggle": ["libs/shared-ui/toggle/index.ts"],
      "@ui/shared-ui/tooltip": ["libs/shared-ui/tooltip/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
